LLM_PROVIDER=auto
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_MODEL=google/gemma-4-E2B-it
VLLM_SUMMARY_MODEL=google/gemma-4-E2B-it
VLLM_API_KEY=EMPTY
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=batiai/gemma4-e2b:q4
OLLAMA_SUMMARY_MODEL=batiai/gemma4-e2b:q4
# Telegram gateway (chorus --telegram or chorus --daemon --telegram)
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional: restrict bot to specific user IDs (comma-separated numeric IDs)
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=

SERPER_API_KEY=your_serper_key_here
GOOGLE_CSE_API_KEY=your_google_cse_key_here
GOOGLE_CSE_ID=your_google_cse_id_here
WEATHER_API_KEY=your_weather_api_key_here
# Set to 1 to disable deepagents TodoListMiddleware (workaround for Gemma4 reasoning suppression)
DISABLE_TODO_MIDDLEWARE=0
# Maximum LangGraph supersteps per run (~2 supersteps per tool call round). Default: 2000
# LANGGRAPH_RECURSION_LIMIT=2000
