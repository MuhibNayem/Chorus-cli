{
  "name": "chorus-agent-cli",
  "version": "0.1.6",
  "description": "A high-performance, local-first interactive agent harness for production coding tasks. Multi-agent orchestration with Ollama, OpenAI, DeepSeek, and more.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chorus": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "docs",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "llm",
    "ollama",
    "openai",
    "deepseek",
    "coding",
    "terminal",
    "tui",
    "ink",
    "ai-native"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "postinstall": "node scripts/download-minilm.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "glob": "^13.0.6",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "left-pad": "^1.3.0",
    "react": "^18.0.0",
    "tiktoken": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}