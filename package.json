{
  "name": "chorus-agent-cli",
  "version": "0.4.0",
  "description": "The most powerful open-source AI coding agent for the terminal. Goal-driven autonomous loops, side-channel conversations, pre-flight advisor workers, multi-agent swarms, adaptive skills, full-diff file rendering, and MCP with OAuth.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chorus": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "docs",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "llm",
    "ollama",
    "openai",
    "deepseek",
    "coding",
    "terminal",
    "tui",
    "ink",
    "ai-native",
    "multi-agent",
    "swarm",
    "mcp",
    "goal-driven",
    "coding-agent",
    "pair-programming",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuhibNayem/Chorus-cli.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "postinstall": "node scripts/download-minilm.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "glob": "^13.0.6",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "left-pad": "^1.3.0",
    "react": "^18.0.0",
    "telegraf": "^4.16.3",
    "tiktoken": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
